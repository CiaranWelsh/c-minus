modules = ["java-graalvm22.3", "bash", "python-3.11"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["mono"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mini_compiler_demo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build_mini_compiler"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "view_ast"

[[workflows.workflow]]
name = "mini_compiler_demo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = """
bash -c \"cd mini-compiler && echo 'Compiling Cmm program...' && java -cp antlr-4.13.2-complete.jar:build Main input.txt output.txt && echo 'Compilation successful! Generated assembly:' && cat output.txt && echo -e '

Executing program...' && echo 'Output:' && mono TextVM.exe output.txt\""""

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "build_mini_compiler"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c \"cd mini-compiler && echo 'Generating parser files...' && java -jar antlr-4.13.2-complete.jar src/parser/Cmm.g4 -package parser -no-listener && echo 'Compiling Java sources...' && find src -name '*.java' ! -name 'MainIntrospector.java' ! -name 'TestRig*.java' | xargs javac -cp antlr-4.13.2-complete.jar -d build && echo 'Build complete!'\""

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "view_ast"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c \"cd mini-compiler && echo 'Building AST from input.txt...' && java -cp antlr-4.13.2-complete.jar:build MainASTViewer input.txt\""

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "scheduled"
run = ["bash", "-c", "java -cp antlr-4.13.2-complete.jar:. Main input.txt output.txt && echo 'Compilation successful! Generated assembly:' && cat output.txt && echo 'Executing program...' && mono TextVM.exe output.txt"]
